---
layout: null
---

[
  {%- assign first = true -%}
  {%- for col in site.collections -%}
    {%- for doc in col.docs -%}
      {%- unless first -%},{%- endunless -%}
      {
        "id": "{{ doc.url | slugify }}",
        "title": {{ doc.title | jsonify }},
        "content": {{ doc.content | markdownify | strip_html | strip_newlines | jsonify }},
        "url": {{ doc.url | relative_url | jsonify }},
        "platform": {{ doc.platform | join: ", " | jsonify }},
        "subjects": {{ doc.subjects | join: ", " | jsonify }},
        "support_level": {{ doc["support-level"] | join: ", " | jsonify }},
        "sw_hw": {{ doc["sw-hw"] | join: ", " | jsonify }},
        "status": {{ doc.status | join: ", " | jsonify }},
        "publication_date": {{ doc["publication-date"] | jsonify }}
      }
      {%- assign first = false -%}
    {%- endfor -%}
  {%- endfor -%}
]
